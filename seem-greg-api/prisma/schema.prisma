generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Game {
  id          String   @id @default(uuid())
  name        String
  emoji       String
  imageUrl    String?  // Optional uploaded image path, served from /uploads/games/
  color       String
  badge       String   @default("")
  category    String
  description String
  gameUrl     String?
  isNew       Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("games")
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  passwordHash String
  role         String         @default("admin")
  createdAt    DateTime       @default(now())
  refreshTokens RefreshToken[]

  @@map("users")
}

// Stored refresh tokens — allows server-side revocation
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique          // hashed token stored here
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent String?                   // browser/device UA string at login
  ipAddress String?                   // client IP at login
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?                 // null = still valid

  @@index([userId])
  @@map("refresh_tokens")
}

// ── Lucky Spin Wheel ─────────────────────────────────────────────────────────

// Admin-configurable reward items displayed on the wheel
model SpinReward {
  id        String   @id @default(uuid())
  label     String                       // e.g. "$5 Bonus", "Free Spin", "50 Credits"
  color     String   @default("#00d4ff") // hex colour for the wheel segment
  weight    Int      @default(1)         // higher = more likely to land
  sortOrder Int      @default(0)         // determines segment ordering on wheel
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("spin_rewards")
}

// One row per unique device fingerprint — auto-cleaned after 24 h
model AnonymousSpin {
  id          String   @id @default(uuid())
  fingerprint String   @unique            // hardware hash from FingerprintJS
  reward      String                      // label of the reward they won
  lastSpunAt  DateTime @default(now())

  @@map("anonymous_spins")
}